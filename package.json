{
  "name": "astack",
  "version": "0.1.0",
  "private": true,
  "description": "AI Harness System — manage Claude/Cursor/CodeBuddy skills across projects",
  "license": "MIT",
  "author": "alexjhwen",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm -r run test:coverage",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "web:build": "pnpm -C packages/web build",
    "server:refresh": "pnpm -C packages/web build && (astack server stop || true) && astack server start"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
