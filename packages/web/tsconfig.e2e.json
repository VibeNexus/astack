{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist-e2e",
    "rootDir": ".",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "composite": false,
    "types": ["@playwright/test", "node"]
  },
  "include": ["e2e/**/*.ts", "playwright.config.ts"]
}
